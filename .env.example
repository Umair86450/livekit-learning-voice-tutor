# LiveKit connection
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Groq API (required for STT + LLM)
GROQ_API_KEY=

# Model configuration
# STT: groq = cloud (default), local = faster-whisper (no API key)
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3-turbo
LLM_MODEL=llama-3.3-70b-versatile

# Local STT (when STT_PROVIDER=local): model size tiny|base|small|medium|large-v3
# LOCAL_STT_MODEL=base
# LOCAL_STT_DEVICE=cpu
# LOCAL_STT_COMPUTE_TYPE=int8
# LOCAL_STT_DOWNLOAD_ROOT=models/whisper

# Language
STT_LANGUAGE=en

# Piper TTS (local)
PIPER_MODEL_PATH=models/en_US-lessac-high.onnx

# Realistic call — turn detection (EOU): lower = faster response; higher = fewer mid-sentence cuts
MIN_ENDPOINTING_DELAY=0.25
MAX_ENDPOINTING_DELAY=1.5

# Realistic call: when caller speaks over you, stop and listen (barge-in). Set false to never be interrupted.
ALLOW_INTERRUPTIONS=true

# Optional: interruption tuning (defaults are good for realistic feel)
# MIN_INTERRUPTION_DURATION=0.5
# MIN_INTERRUPTION_WORDS=0
# FALSE_INTERRUPTION_TIMEOUT=2.0
# RESUME_FALSE_INTERRUPTION=true
# DISCARD_AUDIO_IF_UNINTERRUPTIBLE=true

# Optional: VAD (Silero) — faster EOU = lower min_silence_duration (e.g. 0.45). Leave unset for defaults.
# VAD_MIN_SILENCE_DURATION=
# VAD_MIN_SPEECH_DURATION=
# VAD_ACTIVATION_THRESHOLD=

# RAG (prepared dataset + local Qdrant + open-source embeddings)
# RAG_ENABLED=true
# RAG_DATA_DIR=data/panaversity_rag_prepared
# RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# RAG_QDRANT_URL=http://localhost:6333
# RAG_QDRANT_API_KEY=
# RAG_QDRANT_COLLECTION_MICRO=panaversity_micro
# RAG_QDRANT_COLLECTION_SECTION=panaversity_section
# RAG_QDRANT_RECREATE_COLLECTIONS=false
# RAG_ALLOW_INGEST_ON_START=false
# RAG_FAIL_FAST_ON_INIT_ERROR=true
# RAG_BATCH_SIZE=64
# RAG_TOP_K_EXACT=3
# RAG_TOP_K_EXPLAIN=2
# RAG_MAX_CONTEXT_CHARS=1000
# RAG_OBSERVABILITY_LOGS=true
# DEBUG_METRICS_LOGS=false
